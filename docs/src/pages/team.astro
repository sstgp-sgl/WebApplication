---
import Layout from '../layouts/Layout.astro';
import PageHeader from '../components/PageHeader.astro';
import Section from '../components/Section.astro';
import TeamMember from '../components/TeamMember.astro';

// Team member data
const teamMembers = [
	{
		name: "Chengyang Du",
		id: "2360818",
		avatar: "avatar-chengyang.jpg",
		role: "Team Member",
		bio: "Contributing to the design and development of Gradventure, focusing on creating an engaging experience for students preparing for study abroad applications.",
		skills: ["Design", "Development", "Research"]
	},
	{
		name: "Gulong Sun",
		id: "2362272",
		avatar: "avatar-gulong.jpg",
		role: "Team Member",
		bio: "I am a third-year undergraduate student majoring in ICS. I have taken several programming and algorithms courses in the past. I am really looking forward to taking CPT208 and collaborating with everyone in the class.",
		skills: ["Design", "Development", "Research"]
	},
	{
		name: "Yanhan Jin",
		id: "2362139",
		avatar: "avatar-yanhan.jpg",
		role: "Team Member",
		bio: "I am a third-year undergraduate student at Xi'an Jiaotong-Liverpool University, majoring in Information and Computing Science. During my academic journey, I have gained experience in programming, data processing, and algorithm design. I am excited to collaborate with my team members and contribute to meaningful work together.",
		skills: ["Design", "Development", "Research"]
	},
	{
		name: "Yixuan Zheng",
		id: "2362357",
		avatar: "avatar-yixuan.jpg",
		role: "Team Member",
		bio: "As a third-year ICS student at Xi'an Jiaotong-Liverpool University, I'm particularly interested in how computing can be applied to real-world problems. I've explored areas like data analysis and machine learning, and I enjoy the process of turning data into useful insights. I'm looking forward to learning from my teammates and contributing to our work together.",
		skills: ["Design", "Development", "Research"]
	}
];
---

<Layout title="HCI Portfolio | Team">
	<PageHeader
		title="Meet The Team"
		subtitle="The four designers and developers behind Gradventure."
	/>

	<Section title="Our Team">
		<p class="text-neutral-400 max-w-3xl mb-12 leading-relaxed">
			We are a group of four students with diverse backgrounds in design, development, and education.
			Together, we're building <span class="text-white font-semibold">Gradventure</span> — an engaging platform
			to help students navigate the study abroad application process through gamification.
		</p>

		<div class="grid grid-cols-1 md:grid-cols-2 gap-px bg-border-dark border border-border-dark">
			{teamMembers.map(member => (
				<div class="bg-bg-darker">
					<TeamMember {...member} />
				</div>
			))}
		</div>
	</Section>

	<Section title="Roles & Responsibilities" class="bg-bg-darker/30 border-t border-b border-border-dark">
		<div class="grid grid-cols-1 md:grid-cols-2 gap-8">
			<div class="border border-border-dark p-6 bg-bg-dark">
				<h3 class="text-white font-mono text-sm mb-3">// Design</h3>
				<p class="text-neutral-400 text-sm leading-relaxed">
					User research, persona development, wireframing, prototyping, visual design,
					and ensuring accessibility throughout the application.
				</p>
			</div>
			<div class="border border-border-dark p-6 bg-bg-dark">
				<h3 class="text-white font-mono text-sm mb-3">// Development</h3>
				<p class="text-neutral-400 text-sm leading-relaxed">
					Frontend implementation with modern frameworks, backend architecture,
					database design, API development, and deployment.
				</p>
			</div>
			<div class="border border-border-dark p-6 bg-bg-dark">
				<h3 class="text-white font-mono text-sm mb-3">// Content</h3>
				<p class="text-neutral-400 text-sm leading-relaxed">
					Curriculum development, gamification strategy, learning path design,
					and ensuring educational content is accurate and engaging.
				</p>
			</div>
			<div class="border border-border-dark p-6 bg-bg-dark">
				<h3 class="text-white font-mono text-sm mb-3">// Testing</h3>
				<p class="text-neutral-400 text-sm leading-relaxed">
					User testing coordination, feedback analysis, quality assurance,
					and iterative improvements based on real user data.
				</p>
			</div>
		</div>
	</Section>

	<Section title="Project Timeline">
		<div class="relative">
			<!-- Timeline line -->
			<div class="absolute left-4 md:left-1/2 top-0 bottom-0 w-px bg-border-dark"></div>

			<div class="space-y-12">
				<!-- Phase 1 -->
				<div class="relative flex items-start md:justify-center">
					<div class="absolute left-4 md:left-1/2 w-3 h-3 bg-bg-dark border-2 border-brand-accent -translate-x-1/2 mt-1.5"></div>
					<div class="ml-12 md:ml-0 md:w-1/2 md:pr-12 md:text-right">
						<span class="text-brand-accent font-mono text-sm">Weeks 1-3</span>
						<h3 class="text-white font-bold mt-1">Research & Ideation</h3>
						<p class="text-neutral-400 text-sm mt-2">Problem definition, user research, competitive analysis, initial concepts</p>
					</div>
				</div>

				<!-- Phase 2 -->
				<div class="relative flex items-start md:justify-center md:flex-row-reverse">
					<div class="absolute left-4 md:left-1/2 w-3 h-3 bg-bg-dark border-2 border-brand-accent -translate-x-1/2 mt-1.5"></div>
					<div class="ml-12 md:ml-0 md:w-1/2 md:pl-12">
						<span class="text-brand-accent font-mono text-sm">Weeks 4-6</span>
						<h3 class="text-white font-bold mt-1">Design & Prototyping</h3>
						<p class="text-neutral-400 text-sm mt-2">Information architecture, wireframes, low-fi and hi-fi prototypes</p>
					</div>
				</div>

				<!-- Phase 3 -->
				<div class="relative flex items-start md:justify-center">
					<div class="absolute left-4 md:left-1/2 w-3 h-3 bg-bg-dark border-2 border-brand-accent -translate-x-1/2 mt-1.5"></div>
					<div class="ml-12 md:ml-0 md:w-1/2 md:pr-12 md:text-right">
						<span class="text-brand-accent font-mono text-sm">Weeks 7-9</span>
						<h3 class="text-white font-bold mt-1">User Testing</h3>
						<p class="text-neutral-400 text-sm mt-2">Usability testing sessions, feedback collection, iterative improvements</p>
					</div>
				</div>

				<!-- Phase 4 -->
				<div class="relative flex items-start md:justify-center md:flex-row-reverse">
					<div class="absolute left-4 md:left-1/2 w-3 h-3 bg-bg-dark border-2 border-brand-accent -translate-x-1/2 mt-1.5"></div>
					<div class="ml-12 md:ml-0 md:w-1/2 md:pl-12">
						<span class="text-brand-accent font-mono text-sm">Weeks 10-12</span>
						<h3 class="text-white font-bold mt-1">Implementation</h3>
						<p class="text-neutral-400 text-sm mt-2">Development of the web application, content integration, launch preparation</p>
					</div>
				</div>

				<!-- Phase 5 -->
				<div class="relative flex items-start md:justify-center">
					<div class="absolute left-4 md:left-1/2 w-3 h-3 bg-bg-dark border-2 border-brand-accent -translate-x-1/2 mt-1.5"></div>
					<div class="ml-12 md:ml-0 md:w-1/2 md:pr-12 md:text-right">
						<span class="text-brand-accent font-mono text-sm">Weeks 13-15</span>
						<h3 class="text-white font-bold mt-1">Final Delivery</h3>
						<p class="text-neutral-400 text-sm mt-2">Final testing, documentation, portfolio completion, project presentation</p>
					</div>
				</div>
			</div>
		</div>
	</Section>
</Layout>

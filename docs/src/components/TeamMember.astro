---
interface Props {
	name: string;
	role: string;
	bio: string;
	skills?: string[];
	avatar?: string;
	id?: string;
	github?: string;
	linkedin?: string;
	email?: string;
}

const { name, role, bio, skills, avatar, id, github, linkedin, email } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<div class="group relative bg-bg-darker border border-border-dark p-6 transition-all duration-300 hover:border-brand-accent">
	<!-- Corner decorations -->
	<div class="absolute top-0 left-0 w-8 h-8 border-t-2 border-l-2 border-brand-accent/30 group-hover:border-brand-accent/60 transition-colors"></div>
	<div class="absolute bottom-0 right-0 w-8 h-8 border-b-2 border-r-2 border-brand-accent/30 group-hover:border-brand-accent/60 transition-colors"></div>

	<div class="relative z-10">
		<!-- Avatar placeholder -->
		<div class="w-20 h-20 bg-bg-dark border border-border-dark flex items-center justify-center mb-4 overflow-hidden">
			{avatar ? (
				<img src={`${base}${avatar}`} alt={name} class="w-full h-full object-cover" />
			) : (
				<span class="text-3xl text-neutral-500 font-mono font-bold">{name.charAt(0)}</span>
			)}
		</div>

		<!-- ID -->
		{id && (
			<p class="text-neutral-500 font-mono text-xs mb-2">ID: {id}</p>
		)}

		<!-- Name & Role -->
		<h3 class="text-xl font-bold text-white font-display tracking-tight mb-1">{name}</h3>
		<p class="text-brand-accent text-sm font-mono mb-4">{role}</p>

		<!-- Bio -->
		<p class="text-neutral-400 text-sm leading-relaxed mb-6">{bio}</p>

		<!-- Skills -->
		{skills && skills.length > 0 && (
			<div class="flex flex-wrap gap-2 mb-6">
				{skills.map(skill => (
					<span class="px-3 py-1 bg-bg-dark border border-border-dark text-neutral-400 text-xs font-mono">
						{skill}
					</span>
				))}
			</div>
		)}

		<!-- Social Links -->
		<div class="flex items-center gap-4 pt-4 border-t border-border-dark">
			{email && (
				<a href={`mailto:${email}`} class="text-neutral-500 hover:text-white transition-colors" aria-label="Email">
					<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
					</svg>
				</a>
			)}
			{github && (
				<a href={`https://github.com/${github}`} target="_blank" rel="noopener noreferrer" class="text-neutral-500 hover:text-white transition-colors" aria-label="GitHub">
					<svg viewBox="0 0 24 24" class="w-5 h-5 fill-current" aria-hidden="true">
						<path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
					</svg>
				</a>
			)}
			{linkedin && (
				<a href={`https://linkedin.com/in/${linkedin}`} target="_blank" rel="noopener noreferrer" class="text-neutral-500 hover:text-white transition-colors" aria-label="LinkedIn">
					<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
						<path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
					</svg>
				</a>
			)}
		</div>
	</div>
</div>

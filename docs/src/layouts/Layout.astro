---
import '../styles/global.css';
import '@fontsource/space-grotesk/300.css';
import '@fontsource/space-grotesk/400.css';
import '@fontsource/space-grotesk/500.css';
import '@fontsource/space-grotesk/600.css';
import '@fontsource/space-grotesk/700.css';
import '@fontsource/inter/400.css';
import '@fontsource/inter/500.css';
import '@fontsource/inter/600.css';
import '@fontsource/inter/700.css';
import '@fontsource/jetbrains-mono/400.css';

interface Props {
	title: string;
}

const { title } = Astro.props;
const currentPath = Astro.url.pathname;
const base = import.meta.env.BASE_URL;

// Ensure base URL always ends with a slash for consistent linking
const normalizedBase = base.endsWith('/') ? base : `${base}/`;

const navItems = [
  { name: 'Home', path: normalizedBase },
  { name: 'Brainstorm', path: `${normalizedBase}brainstorm/` },
  { name: 'Process', path: `${normalizedBase}process/` },
  { name: 'Prototypes', path: `${normalizedBase}prototypes/` },
  { name: 'Testing', path: `${normalizedBase}testing/` },
  { name: 'Team', path: `${normalizedBase}team/` },
  { name: 'Reflection', path: `${normalizedBase}reflection/` },
];
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="HCI Process Portfolio" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body class="bg-bg-dark text-white selection:bg-brand-accent selection:text-white">
    <!-- Global Technical Background Elements -->
    <div class="fixed inset-0 pointer-events-none z-0">
        <!-- Vertical guidelines -->
        <div class="absolute left-6 md:left-12 top-0 bottom-0 w-px bg-border-dark opacity-40"></div>
        <div class="absolute right-6 md:right-12 top-0 bottom-0 w-px bg-border-dark opacity-40"></div>
        
        <!-- Random corner markers -->
        <div class="absolute top-24 left-6 md:left-12 w-3 h-3 border-t-2 border-l-2 border-brand-accent/50"></div>
        <div class="absolute top-24 right-6 md:right-12 w-3 h-3 border-t-2 border-r-2 border-brand-accent/50"></div>
        <div class="absolute bottom-6 left-6 md:left-12 w-3 h-3 border-b-2 border-l-2 border-brand-accent/50"></div>
        <div class="absolute bottom-6 right-6 md:right-12 w-3 h-3 border-b-2 border-r-2 border-brand-accent/50"></div>
    </div>

    <nav class="glass-nav fixed top-0 w-full z-50">
      <div class="max-w-7xl mx-auto px-6 h-16 flex items-center justify-between">
        <a href={normalizedBase} class="text-xl font-bold tracking-tighter">HCI<span class="text-neutral-500">PORTFOLIO</span></a>
        
        <div class="hidden md:flex items-center space-x-8">
          {navItems.map(item => (
            <a 
              href={item.path} 
              class:list={[
                "text-sm font-medium transition-colors hover:text-white",
                currentPath === item.path || (currentPath + '/') === item.path ? "text-white" : "text-neutral-400"
              ]}
            >
              {item.name}
            </a>
          ))}
          <a 
            href="https://github.com/Dcyaprogrammer/ApplicationWeb" 
            target="_blank" 
            rel="noopener noreferrer"
            class="flex items-center space-x-2 text-neutral-400 hover:text-white transition-colors"
          >
            <svg viewBox="0 0 24 24" class="w-5 h-5 fill-current" aria-hidden="true"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"></path></svg>
          </a>
        </div>

        <!-- Mobile Menu Button (Simple implementation) -->
        <button id="mobile-menu-btn" class="md:hidden text-white p-2">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
          </svg>
        </button>
      </div>
      
      <!-- Mobile Menu -->
      <div id="mobile-menu" class="hidden md:hidden bg-black border-b border-neutral-800 absolute w-full">
        <div class="px-6 py-4 flex flex-col space-y-4">
          {navItems.map(item => (
            <a 
              href={item.path} 
              class:list={[
                "text-sm font-medium transition-colors hover:text-white block",
                currentPath === item.path ? "text-white" : "text-neutral-400"
              ]}
            >
              {item.name}
            </a>
          ))}
        </div>
      </div>
    </nav>

    <main class="pt-24 min-h-screen flex flex-col">
  		<slot />
    </main>

    <footer class="border-t border-neutral-800 py-12 mt-20 bg-black">
      <div class="max-w-7xl mx-auto px-6 grid grid-cols-1 md:grid-cols-2 gap-8">
        <div>
          <h3 class="text-lg font-bold mb-4">HCI Process Portfolio</h3>
          <p class="text-neutral-400 text-sm max-w-md">
            A documentation of the iterative design process for our HCI group project. 
            Focused on minimalist design and architectural aesthetics.
          </p>
        </div>
        <div class="text-right flex flex-col justify-end">
          <p class="text-neutral-500 text-sm">© 2026 Course Project. All rights reserved.</p>
        </div>
      </div>
    </footer>

    <script>
      const btn = document.getElementById('mobile-menu-btn');
      const menu = document.getElementById('mobile-menu');
      
      btn?.addEventListener('click', () => {
        menu?.classList.toggle('hidden');
      });
    </script>
	</body>
</html>
